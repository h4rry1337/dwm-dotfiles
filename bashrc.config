# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'
PS1='┌─\[\e[97m\]\u\[\e[38;5;33m\]@\[\e[97m\]\h [\[\e[38;5;33m\]\w\[\e[97m\]]\n└─\[\e[38;5;33m\]\$\[\e[0m\] '

# past on your ~/.bashrc and apply changes with: 
# source ~/.bashrc
